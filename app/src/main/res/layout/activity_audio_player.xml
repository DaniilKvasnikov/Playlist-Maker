<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_settings">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:background="@color/background_settings"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:navigationIcon="@drawable/ic_back_16"
            app:titleTextColor="@color/text_color_header_settings" />

        <ScrollView
            android:id="@+id/scroll_view"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/toolbar">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/track_cover"
                    android:layout_width="312dp"
                    android:layout_height="312dp"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:src="@drawable/ic_placeholder_45"
                    android:layout_marginTop="26dp"/>

                <TextView
                    android:id="@+id/track_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/ys_display_medium"
                    android:gravity="start"
                    android:textColor="@color/text_color_settings"
                    android:textSize="22sp"
                    app:layout_constraintEnd_toEndOf="@+id/track_cover"
                    app:layout_constraintStart_toStartOf="@+id/track_cover"
                    app:layout_constraintTop_toBottomOf="@+id/track_cover"
                    tools:text="Yesterday (Remastered 2009)" />

                <TextView
                    android:id="@+id/artist_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/ys_display_medium"
                    android:gravity="start"
                    android:textColor="@color/text_color_settings"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="@+id/track_cover"
                    app:layout_constraintStart_toStartOf="@+id/track_cover"
                    app:layout_constraintTop_toBottomOf="@+id/track_name"
                    tools:text="The Beatles" />

                <ImageButton
                    android:id="@+id/play_button"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginTop="30dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_play_button_100"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/artist_name" />

                <ImageButton
                    android:id="@+id/add_to_playlist_button"
                    android:layout_width="51dp"
                    android:layout_height="51dp"
                    android:background="@drawable/button_rounded_background"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_add_button_23"
                    app:layout_constraintStart_toStartOf="@+id/track_cover"
                    app:layout_constraintTop_toTopOf="@+id/play_button"
                    app:layout_constraintBottom_toBottomOf="@+id/play_button"
                    app:layout_constraintHorizontal_chainStyle="packed"/>

                <ImageButton
                    android:id="@+id/add_to_favorites_button"
                    android:layout_width="51dp"
                    android:layout_height="51dp"
                    android:layout_marginStart="55dp"
                    android:background="@drawable/button_rounded_background"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_like_button_25"
                    app:layout_constraintEnd_toEndOf="@+id/track_cover"
                    app:layout_constraintTop_toTopOf="@+id/play_button"
                    app:layout_constraintBottom_toBottomOf="@+id/play_button"/>

                <TextView
                    android:id="@+id/play_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/ys_display_medium"
                    android:gravity="center"
                    android:textColor="@color/text_color_settings"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="@+id/play_button"
                    app:layout_constraintStart_toStartOf="@+id/play_button"
                    app:layout_constraintTop_toBottomOf="@+id/play_button"
                    tools:text="0:30"/>

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.3" />

                <TextView
                    android:id="@+id/duration_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="9dp"
                    android:paddingBottom="8dp"
                    android:fontFamily="@font/ys_display_regular"
                    android:text="@string/duration"
                    android:textColor="@color/item_track_info_play"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toStartOf="@+id/guideline"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/play_time" />

                <TextView
                    android:id="@+id/duration_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/ys_display_regular"
                    android:gravity="end"
                    android:paddingStart="16dp"
                    android:paddingTop="9dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:textColor="@color/text_color_settings"
                    android:textSize="13sp"
                    app:layout_constraintBaseline_toBaselineOf="@+id/duration_label"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toEndOf="@+id/guideline"
                    tools:text="5:35" />

                <TextView
                    android:id="@+id/album_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="9dp"
                    android:paddingBottom="8dp"
                    android:fontFamily="@font/ys_display_regular"
                    android:text="@string/album"
                    android:textColor="@color/item_track_info_play"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toStartOf="@+id/guideline"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/duration_label" />

                <TextView
                    android:id="@+id/album_value"
                    android:layout_width="0dp"
                    android:gravity="end"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="9dp"
                    android:paddingBottom="8dp"
                    android:fontFamily="@font/ys_display_regular"
                    android:textColor="@color/text_color_settings"
                    android:textSize="13sp"
                    app:layout_constraintStart_toEndOf="@+id/guideline"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBaseline_toBaselineOf="@+id/album_label"
                    tools:text="Yesterday" />

                <TextView
                    android:id="@+id/year_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="9dp"
                    android:paddingBottom="8dp"
                    android:fontFamily="@font/ys_display_regular"
                    android:text="@string/year"
                    android:textColor="@color/item_track_info_play"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toStartOf="@+id/guideline"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/album_value" />

                <TextView
                    android:id="@+id/year_value"
                    android:layout_width="0dp"
                    android:gravity="end"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="9dp"
                    android:paddingBottom="8dp"
                    android:fontFamily="@font/ys_display_regular"
                    android:textColor="@color/text_color_settings"
                    android:textSize="13sp"
                    app:layout_constraintStart_toEndOf="@+id/guideline"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBaseline_toBaselineOf="@+id/year_label"
                    tools:text="1965" />

                <TextView
                    android:id="@+id/genre_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="9dp"
                    android:paddingBottom="8dp"
                    android:fontFamily="@font/ys_display_regular"
                    android:text="@string/genre"
                    android:textColor="@color/item_track_info_play"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toStartOf="@+id/guideline"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/year_label" />

                <TextView
                    android:id="@+id/genre_value"
                    android:layout_width="0dp"
                    android:gravity="end"
                    android:layout_height="wrap_content"
                    android:paddingStart="0dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="9dp"
                    android:paddingBottom="8dp"
                    android:fontFamily="@font/ys_display_regular"
                    android:textColor="@color/text_color_settings"
                    android:textSize="13sp"
                    app:layout_constraintStart_toEndOf="@+id/guideline"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBaseline_toBaselineOf="@+id/genre_label"
                    tools:text="Rock" />

                <TextView
                    android:id="@+id/country_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="9dp"
                    android:paddingBottom="8dp"
                    android:fontFamily="@font/ys_display_regular"
                    android:text="@string/country"
                    android:textColor="@color/item_track_info_play"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toStartOf="@+id/guideline"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/genre_label" />

                <TextView
                    android:id="@+id/country_value"
                    android:layout_width="0dp"
                    android:gravity="end"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="9dp"
                    android:paddingBottom="8dp"
                    android:fontFamily="@font/ys_display_regular"
                    android:textColor="@color/text_color_settings"
                    android:textSize="13sp"
                    app:layout_constraintStart_toEndOf="@+id/guideline"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBaseline_toBaselineOf="@+id/country_label"
                    tools:text="Великобритания" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/playlists_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bottom_sheet_bg"
        android:orientation="vertical"
        android:padding="0dp"
        app:behavior_hideable="true"
        app:behavior_peekHeight="240dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <View
            android:layout_width="50dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:background="@drawable/ic_rounded_rectangle_full" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:fontFamily="@font/ys_display_medium"
            android:layout_marginTop="30dp"
            android:text="@string/add_to_playlist_title"
            android:textColor="@color/text_color_settings"
            android:textSize="19sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/new_playlist_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="@color/text_color_settings"
            android:fontFamily="@font/ys_display_medium"
            android:textAllCaps="false"
            android:text="@string/new_playlist"
            android:textColor="@color/background"
            android:textSize="14sp"
            android:letterSpacing="0"
            app:cornerRadius="54dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/playlists_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
